# Copy this file to a new file named just ".env" and fill in the real values.
# The .env file stays on your machine and is never committed to git.

# From https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=

# From your Supabase project -> Settings -> API
# SUPABASE_KEY must be the "service_role" secret key (NOT the anon/public one)
SUPABASE_URL=
SUPABASE_KEY=

# From https://dashboard.stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# The three subscription plans. Get these by running:
#   node scripts/setup-stripe.mjs
# then paste the three lines it prints here.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Where Stripe sends users back after checkout (your dashboard).
# Locally this is the Vite dev server; in production it's https://app.fieldr.ie
DASHBOARD_URL=http://localhost:5173

# Secret used to sign login tokens (admin + client portal). Long random string.
# (Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" )
JWT_SECRET=

# Your admin login for the dashboard (app.fieldr.ie). Only you should know these.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Port the API runs on locally
PORT=3001
